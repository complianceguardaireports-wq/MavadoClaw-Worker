# MavadoClaw Worker Environment Variables
# Copy this to .env and fill in values

# === Core ===
PORT=8080
HOSTNAME=0.0.0.0
PYTHONUNBUFFERED=1

# === Free API Keys (all optional - app works without them) ===
# Google AI Studio (free unlimited)
GOOGLE_AI_KEY=

# Groq (14,400 req/day free)
GROQ_KEY=

# DeepSeek (5M tokens free)
DEEPSEEK_KEY=

# OpenRouter ($1 free credit)
OPENROUTER_KEY=

# Mistral (free tier)
MISTRAL_KEY=

# Together.ai ($5 free credit)
TOGETHER_KEY=

# Cerebras (~1M tokens/day free)
CEREBRAS_KEY=

# SambaNova ($5 free credit)
SAMBANOVA_KEY=

# === Cloudflare ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=

# === HuggingFace ===
HF_TOKEN=
HF_SPACE_NAME=

# === Lightning.ai ===
LIGHTNING_API_KEY=

# === Internal Routing ===
OMNIROUTE_URL=http://omniroute:3000
NINEROUTER_URL=http://9router:8081
LOCAL_AUTONOMOUS_KEY=local-autonomous-key
